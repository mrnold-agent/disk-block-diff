# Copy to config.env and fill in values. Never commit config.env.
#
# Option B E2E: VMware helper hashes source once; OpenShift hashes dest;
# workstation diffs; OpenShift repair pod applies repair.jsonl only (no NBD hash).

# --- Disk sizing (use a small test disk, not production capacity) ---
# Used for logging/validation; helper VM disk and OpenShift block PVC must match.
E2E_DISK_SIZE=1GiB
# Hash chunk size; smaller = faster E2E, larger repair.jsonl. Use same on both sides.
E2E_BLOCK_SIZE=64MiB
E2E_HASH_WORKERS=4
E2E_APPLY_WORKERS=2
E2E_PROGRESS_INTERVAL=10s
# Seconds to keep hash pod alive after writing manifest (kubectl cp needs Running container)
E2E_ARTIFACT_HOLD_SECONDS=30

# --- Local work directory (manifests copied here) ---
E2E_WORK_DIR=./e2e-work

# --- VMware helper VM (source manifest only; full read of small test disk) ---
# Leave E2E_HELPER_SSH empty to print manual commands instead of running over SSH.
E2E_HELPER_SSH=
E2E_HELPER_DEVICE=/dev/sdb
# Remote path; run-option-b.sh uploads via /tmp then install (sudo if needed).
E2E_HELPER_BINARY=/usr/local/bin/disk-block-diff
# auto: sudo when /dev/* is not readable; always|never to force
E2E_HELPER_SUDO=auto

# --- OpenShift / Kubernetes (destination hash, repair apply, verify) ---
KUBECONFIG=${KUBECONFIG:-$HOME/.kube/config}
E2E_NAMESPACE=default
E2E_PVC_NAME=disk-block-diff-e2e-target

# E2E image: build with ./e2e/build-image.sh (see e2e/README.md).
# E2E_BASE_IMAGE = CDI importer (IMPORTER_IMAGE on cdi-deployment).
# E2E_VDDK_IMAGE = your private VDDK init image (NOT quay.io/kubev2v/vddk — that is an empty shell).
# Leave E2E_VDDK_IMAGE empty to auto-discover from Forklift provider / v2v-vmware configmap.
E2E_BASE_IMAGE=quay.io/kubevirt/cdi-importer:latest
E2E_VDDK_IMAGE=
E2E_IMAGE=disk-block-diff-e2e:local
# nbdkit extra-args ConfigMap (vddk-config-file key); auto-discovered from migration PVC / Forklift plan
E2E_VDDK_CONFIGMAP=
E2E_VDDK_SECRET_NAME=disk-block-diff-e2e-vddk

# Block device path inside CDI-style pods
E2E_DEST_DEVICE=/dev/cdi-block-volume

# --- vCenter / VDDK (repair pod only: nbd-open + apply, NOT full-disk hash) ---
# USER/PASSWORD are applied to Secret E2E_VDDK_SECRET_NAME when repair runs.
E2E_VCENTER_SERVER=vcenter.example.com
E2E_VCENTER_USER=
E2E_VCENTER_PASSWORD=
E2E_VCENTER_THUMBPRINT=
# Leave empty to auto-discover from E2E_PVC_NAME / DataVolume (CDI warm migration).
E2E_VM_UUID=
E2E_BACKING_FILE=
E2E_SNAPSHOT=

# --- Optional: corrupt one dest block before dest hash to force a repair ---
# Block index (0-based). Empty or 0 with E2E_CORRUPT_DEST=false disables.
E2E_CORRUPT_DEST=false
E2E_CORRUPT_BLOCK_INDEX=1

# --- Pod name prefix (timestamp added by run script) ---
E2E_POD_PREFIX=disk-block-diff-e2e
